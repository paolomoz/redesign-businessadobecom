      "section-header": { "purpose": "eyebrow + title + dek + optional CTA", "rhythm": "section-y spacing above and below" },
      "sticky-cta": { "purpose": "page-bottom contact-sales / try-now anchor on product pages" }
    },
    "voice": {
      "dos": [
        "Unleash creativity at scale.",
        "There's more to Acrobat than Acrobat.",
        "Data and insights for a competitive edge.",
        "Accelerated document workflows that deliver more impact."
